<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="WindowBackgroundColor">#FF101114</Color>
    <Color x:Key="PanelBackgroundColor">#E61A1D23</Color>
    <Color x:Key="PanelBackgroundStrongColor">#F021252C</Color>
    <Color x:Key="PrimaryTextColor">#FFF1F5F9</Color>
    <Color x:Key="SecondaryTextColor">#FFA9B2C0</Color>
    <Color x:Key="AccentColor">#FFC68D37</Color>
    <Color x:Key="AccentHoverColor">#FFD89D45</Color>
    <Color x:Key="BorderColor">#40FFFFFF</Color>
    <Color x:Key="DangerColor">#FFFF6F6F</Color>
    <Color x:Key="SuccessColor">#FF5ED08A</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}" />
    <SolidColorBrush x:Key="PanelBackgroundStrongBrush" Color="{StaticResource PanelBackgroundStrongColor}" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="BorderBrushTheme" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />

    <ImageBrush x:Key="BackgroundTextureBrush" ImageSource="/Assets/background.png" Stretch="UniformToFill" Opacity="0.17" />
    <ImageBrush x:Key="ButtonTextureBrush" ImageSource="/Assets/button_texture.png" Stretch="Fill" Opacity="0.14" />
</ResourceDictionary>
